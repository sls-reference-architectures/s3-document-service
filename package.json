{
  "name": "s3-document-service",
  "version": "1.0.0",
  "description": "A model pre-signed upload/download document service with events and metadata",
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint '**.*.js' --fix",
    "test": "npx jest --testMatch '**/?(*.)+(unit.test).js'",
    "test:e2e": "npx jest --testMatch '**/?(*.)+(e2e.test).js' --config jest.config.e2e.js",
    "test:int": "npx jest --testMatch '**/?(*.)+(int.test).js' --config jest.config.int.js",
    "prepare": "husky"
  },
  "author": "Seth Orell",
  "license": "MIT",
  "devDependencies": {
    "@aws-sdk/client-cloudformation": "^3.1007.0",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.1.0",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "async-retry": "^1.3.3",
    "axios": "^1.16.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-extended": "^7.0.0",
    "lint-staged": "^17.1.0",
    "osls": "^4.0.0",
    "prettier": "^3.9.5",
    "request": "^2.88.2",
    "serverless-esbuild": "^1.57.0",
    "serverless-iam-roles-per-function": "^3.2.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1086.0",
    "@aws-sdk/client-s3": "^3.1007.0",
    "@aws-sdk/lib-dynamodb": "^3.1007.0",
    "@aws-sdk/s3-presigned-post": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@middy/core": "^7.6.5",
    "@middy/http-error-handler": "^7.6.5",
    "@middy/http-event-normalizer": "^7.6.5",
    "@middy/http-json-body-parser": "^7.6.5",
    "@middy/input-output-logger": "^7.6.5",
    "http-errors": "^2.0.1",
    "ulid": "^3.0.1"
  },
  "lint-staged": {
    "*.js": "eslint --cache --fix",
    "*.{js,md,yml,json}": "npx prettier . --write --ignore-path .gitignore"
  }
}
